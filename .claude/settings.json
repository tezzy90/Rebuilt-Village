{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "Glob(**)",
      "Grep(**)",
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npm run build)",
      "Bash(npm run build *)",
      "Bash(npm run dev)",
      "Bash(npm run lint)",
      "Bash(npm run lint *)",
      "Bash(npm run preview)",
      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(npm ci)",
      "Bash(npx depcheck)",
      "Bash(npx depcheck *)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx tsc --noEmit *)",
      "Bash(npx eslint *)",
      "Bash(node *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git restore *)",
      "Bash(git stash)",
      "Bash(git stash *)",
      "Bash(gh pr create *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr status)",
      "Bash(gh pr checks *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh issue create *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh run watch *)",
      "Bash(gh repo view *)",
      "Bash(firebase deploy --only hosting)",
      "Bash(firebase deploy --only hosting:*)",
      "Bash(firebase emulators:start)",
      "Bash(firebase emulators:start *)",
      "Bash(firebase emulators:exec *)",
      "Bash(firebase projects:list)",
      "Bash(firebase use)",
      "Bash(firebase use *)",
      "Bash(firebase firestore:indexes)",
      "Bash(firebase firestore:indexes *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find * -name *)",
      "Bash(find * -type *)",
      "Bash(tree)",
      "Bash(tree *)",
      "Bash(which *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(echo *)",
      "Bash(printf *)"
    ],
    "deny": [
      "Bash(firebase deploy --only functions)",
      "Bash(firebase deploy --only functions:*)",
      "Bash(firebase deploy --only firestore)",
      "Bash(firebase deploy --only firestore:*)",
      "Bash(firebase deploy)",
      "Bash(gcloud *)",
      "Bash(gsutil *)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(sudo *)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(npm publish*)",
      "Bash(stripe *)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/.env.local)",
      "Write(**/.env.production)",
      "Write(**/service-account*.json)",
      "Write(**/firebase-adminsdk*.json)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/.env.local)",
      "Edit(**/.env.production)",
      "Edit(**/service-account*.json)",
      "Edit(**/firebase-adminsdk*.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE \"(sk_live_|rk_live_|pk_live_|AIza[0-9A-Za-z_-]{35}|ghp_[0-9A-Za-z]{36})\"; then echo \"Blocked: possible live API key in content\" >&2; exit 2; fi'"
          }
        ]
      }
    ]
  }
}
