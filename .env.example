# =============================================
# Rebuilt Village — Environment Variables
# Copy to .env.local and fill in values.
# Never commit .env.local to version control.
# =============================================

# --- Firebase / GCP ---
VITE_FIREBASE_PROJECT_ID=rebuilt-village-prod
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=rebuilt-village-prod.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=rebuilt-village-prod.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Stripe ---
# Public key (safe to expose in frontend)
VITE_STRIPE_PUBLIC_KEY=pk_live_...
# Secret key — ONLY used in Cloud Functions, never in frontend
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from your Stripe Dashboard
STRIPE_PRICE_ONE_TIME_25=price_...
STRIPE_PRICE_ONE_TIME_50=price_...
STRIPE_PRICE_ONE_TIME_100=price_...
STRIPE_PRICE_ONE_TIME_250=price_...
STRIPE_PRICE_MONTHLY_25=price_...
STRIPE_PRICE_MONTHLY_50=price_...
STRIPE_PRICE_MONTHLY_100=price_...
STRIPE_PRICE_MONTHLY_250=price_...

# --- Sanity CMS ---
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
SANITY_API_TOKEN=

# --- Resend (transactional email) ---
RESEND_API_KEY=re_...
FROM_EMAIL=hello@rebuiltvillage.org
DONATION_NOTIFY_EMAIL=cortez@321work.com

# --- Google Gemini AI ---
GEMINI_API_KEY=

# --- Analytics ---
VITE_GA_MEASUREMENT_ID=G-...

# --- Dev: Firebase Emulator ---
# Uncomment for local development with emulators
# VITE_USE_EMULATORS=true
# VITE_FUNCTIONS_EMULATOR_HOST=localhost
# VITE_FUNCTIONS_EMULATOR_PORT=5001
